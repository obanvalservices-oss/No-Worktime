# SQLite file is created next to prisma/schema.prisma (i.e. prisma/dev.db)
DATABASE_URL="file:./dev.db"
JWT_SECRET=change-me-to-a-long-random-string

# Local admin (created/updated on server start via instrumentation)
MASTER_USER_EMAIL=admin@local.com
MASTER_USER_PASSWORD=123456

ALLOW_PUBLIC_REGISTER=false

# Public URL of this app (used for Google OAuth redirects in production)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — callback must match exactly, e.g.:
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
