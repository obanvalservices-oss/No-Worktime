DATABASE_URL="file:./dev.db"
JWT_SECRET=change-me-to-a-long-random-string
PORT=4000

# Local admin (created/updated on server start)
MASTER_USER_EMAIL=admin@local.com
MASTER_USER_PASSWORD=123456

# CORS: browser origin(s) for the Vite app (comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:5173

# OAuth redirect after Google login (defaults to CLIENT_URL or CLIENT_ORIGIN)
# CLIENT_URL=http://localhost:5173

# Set true to show Register on the login page even after the first user exists
ALLOW_PUBLIC_REGISTER=false

# Optional Google sign-in (all three required to enable "Continue with Google")
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
