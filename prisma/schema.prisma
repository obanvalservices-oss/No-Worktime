generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  googleId  String?  @unique
  createdAt DateTime @default(now())
  companies Company[]
}

model Company {
  id          String       @id @default(uuid())
  ownerId     String
  name        String
  description String?
  createdAt   DateTime     @default(now())
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  departments Department[]
  employees   Employee[]
  payrollRuns PayrollRun[]
}

model Department {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  kind        String?
  createdAt   DateTime   @default(now())
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@index([companyId])
}

enum PayType {
  HOURLY
  SALARY
}

model Employee {
  id                 String      @id @default(uuid())
  companyId          String
  departmentId       String
  name               String
  payType            PayType
  hourlyRate         Float?
  weeklyBaseSalary   Float?
  overtimeThreshold  Float       @default(40)
  overtimeMultiplier Float       @default(1.5)
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  company            Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department         Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  payrollLines       PayrollLine[]

  @@index([companyId])
  @@index([departmentId])
}

enum PayrollStatus {
  DRAFT
  FINALIZED
}

model PayrollRun {
  id        String         @id @default(uuid())
  companyId String
  startDate String
  endDate   String
  status    PayrollStatus  @default(DRAFT)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines     PayrollLine[]

  @@index([companyId])
}

model PayrollLine {
  id                 String       @id @default(uuid())
  runId              String
  employeeId         String
  hourlyRateSnapshot Float?
  weeklySalaryAmount Float?
  overtimeThreshold  Float        @default(40)
  overtimeMultiplier Float        @default(1.5)
  regularHours       Float?
  overtimeHours      Float?
  regularPay         Float?
  overtimePay        Float?
  grossPay           Float?
  run                PayrollRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  employee           Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  timeEntries        TimeEntry[]

  @@unique([runId, employeeId])
  @@index([runId])
}

model TimeEntry {
  id         String      @id @default(uuid())
  lineId     String
  workDate   String
  clockIn    String?
  clockOut   String?
  clockIn2   String?
  clockOut2  String?
  line       PayrollLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@unique([lineId, workDate])
  @@index([lineId])
}
