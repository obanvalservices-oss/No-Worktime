# =============================================================================
# NO Worktime — environment variables
# Copy to `.env` locally. On Railway, set these in the service Variables UI.
# Production URL: https://no-worktime.nestorobando.com
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# Supabase: Project Settings → Database → Connection string → URI
# Use the direct connection (port 5432) so Prisma Migrate and the app work reliably.
# Example:
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
#
# If you use Supabase Transaction pooler (6543 + ?pgbouncer=true), add to prisma/schema.prisma:
#   directUrl = env("DIRECT_URL")
# and set DIRECT_URL to the session/direct Postgres URL (5432) for migrations only.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# --- Auth --------------------------------------------------------------------
# Generate:  openssl rand -base64 48
JWT_SECRET=

# Bootstrap user (created/updated on server start via instrumentation.ts)
# Use a strong password in production.
MASTER_USER_EMAIL=admin@yourdomain.com
MASTER_USER_PASSWORD=

# Set true only if you want open self-service registration
ALLOW_PUBLIC_REGISTER=false

# Public site URL (no trailing slash). Required for correct OAuth redirects and metadata.
NEXT_PUBLIC_APP_URL=https://no-worktime.nestorobando.com

# Optional: force Secure cookies when not NODE_ENV=production (e.g. local HTTPS)
# COOKIE_SECURE=true

# --- Google OAuth (optional) -------------------------------------------------
# Authorized redirect URI in Google Cloud Console must match exactly:
#   https://no-worktime.nestorobando.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://no-worktime.nestorobando.com/api/auth/google/callback

# --- Railway -----------------------------------------------------------------
# PORT is injected automatically. Do not set manually unless debugging.
